# === Configurazione Macàri Bistrot Backend ===

# Porta su cui il server Express ascolta
PORT=4000

# Host: 0.0.0.0 = accessibile da tutta la rete locale (Wi-Fi del locale)
HOST=0.0.0.0

# Ambiente: development | production
NODE_ENV=development

# Origine consentita per CORS (frontend in sviluppo)
# In produzione, l'app viene servita dallo stesso server, quindi puoi lasciare vuoto.
CORS_ORIGIN=http://localhost:5173

# Password admin per accedere al pannello (cambiala assolutamente!)
ADMIN_PASSWORD=macari2024

# Dimensione massima file upload (in MB)
MAX_UPLOAD_MB=5
