{
  "name": "macari-bistrot",
  "version": "1.0.0",
  "private": true,
  "description": "Menù digitale e stampabile del Macàri Bistrot — SPA locale offline",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "install:all":   "npm install --prefix backend && npm install --prefix frontend && npm install --no-save qrcode-terminal",
    "seed":          "npm run seed --prefix backend",
    "dev:backend":   "npm run dev --prefix backend",
    "dev:frontend":  "npm run dev --prefix frontend",
    "build":         "npm run build --prefix frontend",
    "start":         "npm start --prefix backend",
    "qr":            "node scripts/show-qr.js",
    "package:win":   "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1"
  },
  "devDependencies": {}
}
